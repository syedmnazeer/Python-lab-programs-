import os

def show_contents(path):

    # Get all items in folder
    items = os.listdir(path)

    for item in items:

        # Create full path
        full_path = os.path.join(path, item)

        # Check if item is folder
        if os.path.isdir(full_path):
            print("Folder:", item)

            # Go inside folder
            show_contents(full_path)

        else:
            print("File:", item)


folder = input("Enter folder path: ")
show_contents(folder)