a = float(input("Enter first number: "))
b = float(input("Enter second number: "))

print("Select choice:")
print("1. Add")
print("2. Subtract")
print("3. Multiply")
print("4. Divide")

c = int(input("Enter your choice: "))

if c == 1:
    print("Add =", a + b)

elif c == 2:
    print("Sub =", a - b)

elif c == 3:
    print("Mul =", a * b)

elif c == 4:
    if b != 0:
        print("Div =", a / b)
    else:
        print("Error: Division by zero")

else:
    print("Invalid choice")
